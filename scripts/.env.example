# ============================================
# WasaiTalent 部署配置示例
# ============================================
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 根据实际情况修改 .env 中的配置值
# 3. .env 文件包含敏感信息，已在 .gitignore 中忽略
# ============================================

# 目标服务器配置
SERVER_IP="your.server.ip.address"
SERVER_USER="root"

# 目标部署目录
TARGET_DIR="/opt/wasaitalent"
